# Gere com: openssl rand -hex 32
SECRET_KEY=sua_chave_secreta_aqui_minimo_32_chars

# SQLite (dev) ou PostgreSQL (produção)
DATABASE_URL=sqlite:///./zentrix.db
# DATABASE_URL=postgresql://user:password@localhost:5432/zentrix

# URLs permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173

ACCESS_TOKEN_EXPIRE_MINUTES=1440
